<% content_for :title, "Users" %>

<div class="w-full container mx-auto px-5 mt-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl text-gray-900 dark:text-gray-100">Users</h1>
    <% if @auth_user %>
      <%= link_to "+ New user", new_user_path, class: "rounded-xl px-4 py-2.5 bg-purple-600 hover:bg-purple-500 text-white font-semibold text-sm transition-colors duration-200" %>
    <% end %>
  </div>

  <% if @users.any? %>
    <div id="users" class="space-y-3">
      <% @users.each do |user| %>
        <%= render user %>
      <% end %>
    </div>
    <p class="text-gray-400 dark:text-gray-500 text-sm mt-6"><%= @users.count %> users total</p>
  <% else %>
    <div class="text-center py-24 text-gray-400">
      <p class="text-lg font-medium">No users yet.</p>
      <% if @auth_user %>
        <p class="mt-2 text-sm"><%= link_to "Create one →", new_user_path, class: "text-purple-600 dark:text-purple-400 hover:underline" %></p>
      <% end %>
    </div>
  <% end %>
</div>
