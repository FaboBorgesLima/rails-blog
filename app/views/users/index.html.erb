<% content_for :title, "Users" %>

<div class="w-full max-w-4xl mx-auto px-4 py-8">
  <% if notice.present? %>
    <div class="flex items-center gap-2 py-3 px-4 bg-green-50 border border-green-200 mb-6 text-green-700 font-medium rounded-xl shadow-sm" id="notice">
      <span>&#10003;</span> <%= notice %>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="font-bold text-3xl text-gray-900">Users</h1>
      <p class="text-gray-500 text-sm mt-1"><%= @users.count %> total</p>
    </div>
    <%= link_to "+ New user", new_user_path, class: "rounded-xl px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium shadow-sm transition-colors" %>
  </div>

  <div id="users" class="space-y-3">
    <% if @users.any? %>
      <% @users.each do |user| %>
        <%= render user %>
      <% end %>
    <% else %>
      <div class="text-center py-16 bg-white rounded-xl border border-dashed border-gray-300">
        <p class="text-gray-400 text-lg">No users found.</p>
        <%= link_to "Create the first one", new_user_path, class: "mt-3 inline-block text-blue-600 hover:underline text-sm" %>
      </div>
    <% end %>
  </div>
</div>
