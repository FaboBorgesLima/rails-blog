<div id="<%= dom_id user %>" class="bg-white dark:bg-gray-950 border border-purple-100 dark:border-purple-900/40 rounded-2xl shadow-sm p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 hover:shadow-md hover:shadow-purple-100/50 dark:hover:shadow-purple-900/20 transition-shadow">
  <div class="flex items-center gap-4">
    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-violet-700 flex items-center justify-center text-white font-bold text-lg shadow-sm shadow-purple-200 dark:shadow-purple-900/50">
      <%= user.name[0].upcase %>
    </div>
    <div>
      <p class="font-semibold text-gray-900 dark:text-gray-100"><%= user.name %></p>
      <p class="text-sm text-gray-400 dark:text-gray-500"><%= user.email %></p>
    </div>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "View", user, class: "rounded-xl px-4 py-2 bg-purple-50 dark:bg-purple-950/50 hover:bg-purple-100 dark:hover:bg-purple-900/40 border border-purple-100 dark:border-purple-900/50 text-purple-700 dark:text-purple-300 font-medium text-sm transition-colors" %>
    <%= link_to "Edit", edit_user_path(user), class: "rounded-xl px-4 py-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 hover:border-purple-300 dark:hover:border-purple-700 text-gray-700 dark:text-gray-300 font-medium text-sm transition-colors" %>
    <%= button_to "Delete", user, method: :delete, class: "rounded-xl px-4 py-2 text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950/40 hover:bg-red-100 dark:hover:bg-red-900/40 border border-red-100 dark:border-red-900/50 font-medium text-sm cursor-pointer transition-colors", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
