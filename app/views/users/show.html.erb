<% content_for :title, @user.name %>

<div class="container mx-auto px-5 mt-8">
  <div class="max-w-2xl mx-auto">

    <div class="bg-white dark:bg-gray-900 rounded-3xl border border-purple-100 dark:border-purple-900/40 shadow-xl shadow-purple-100/50 dark:shadow-purple-900/20 p-8">

      <div class="flex items-center gap-5 mb-8 pb-7 border-b border-purple-50 dark:border-purple-900/30">
        <div class="shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-500 to-violet-700 flex items-center justify-center text-white font-extrabold text-2xl shadow-md shadow-purple-200 dark:shadow-purple-900/50">
          <%= @user.name[0].upcase %>
        </div>
        <div>
          <h1 class="font-extrabold text-2xl text-gray-900 dark:text-gray-100"><%= @user.name %></h1>
          <p class="text-gray-400 dark:text-gray-500 text-sm mt-0.5"><%= @user.email %></p>
          <% if @user.description.present? %>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-2"><%= @user.description %></p>
          <% end %>
          <div class="flex items-center gap-3 mt-3">
            <% if @user.github_url.present? %>
              <%= link_to safe_external_url(@user.github_url), target: "_blank", rel: "noopener noreferrer", class: "text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors flex items-center" do %>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                <span class="ml-1"><%= @user.get_github_username %></span>
              <% end %>
            <% end %>
            <% if @user.linkedin_url.present? %>
              <%= link_to safe_external_url(@user.linkedin_url), target: "_blank", rel: "noopener noreferrer", class: "text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors flex items-center" do %>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <span class="ml-1"><%= @user.get_linkedin_username %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <% if @auth_user && @auth_user.can_edit?(@user) %>
          <%= link_to "Edit profile", edit_user_path(@user), class: "rounded-2xl px-5 py-2.5 bg-purple-600 hover:bg-purple-500 text-white font-semibold text-sm transition-all duration-200 hover:shadow-lg hover:shadow-purple-200 dark:hover:shadow-purple-900/50 hover:-translate-y-0.5" %>
        <% end %>
        <%= link_to "← Back", root_path, class: "rounded-2xl px-5 py-2.5 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 hover:border-purple-300 dark:hover:border-purple-700 text-gray-700 dark:text-gray-300 font-semibold text-sm transition-all duration-200 hover:shadow-md" %>
      </div>
    </div>

  </div>
</div>
