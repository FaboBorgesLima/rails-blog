<% content_for :title, "Editing post" %>

<div class="container mx-auto px-5 mt-8">
  <div class="mx-auto max-w-2xl">
    <div class="mb-8">
      <h1 class="font-extrabold text-4xl text-gray-900 dark:text-gray-100">Edit post</h1>
      <p class="text-gray-400 dark:text-gray-500 mt-1 text-sm">Update your post below.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-3xl border border-purple-100 dark:border-purple-900/40 shadow-xl shadow-purple-100/50 dark:shadow-purple-900/20 p-8 space-y-6">
      <%= render "form", post: @post %>
    </div>

    <div class="flex gap-4 mt-5">
      <%= link_to "← Back to posts", root_path, class: "text-sm font-medium text-gray-400 dark:text-gray-500 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200" %>
    </div>
  </div>
</div>
