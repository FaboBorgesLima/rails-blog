<% content_for :title, @post.title %>

<div class="container mx-auto px-5 my-8">
  <article class="mx-auto max-w-3xl">

    <div class="bg-white dark:bg-gray-950 rounded-3xl border border-purple-100 dark:border-purple-900/40 shadow-xl shadow-purple-100/50 dark:shadow-purple-900/20 p-8 md:p-12">
      <div class="mb-8">
        <h1 class="font-extrabold text-4xl text-gray-900 dark:text-gray-100 leading-tight"><%= @post.title %></h1>
        <% if @post.description.present? %>
          <p class="mt-3 text-lg text-gray-500 dark:text-gray-400"><%= @post.description %></p>
        <% end %>
        <div class="flex items-center gap-2 mt-5">
          <a href="<%= user_path(@post.user) %>" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-purple-50 dark:bg-purple-950/50 border border-purple-100 dark:border-purple-900/50 text-purple-700 dark:text-purple-300 text-xs font-medium">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <%= @post.user&.name %>
          </a>
          <span class="text-gray-300 dark:text-gray-600">&middot;</span>
          <time class="text-xs text-gray-400 dark:text-gray-500"><%= @post.created_at.strftime("%B %d, %Y") %></time>
        </div>
      </div>

      <div class="prose dark:prose-invert prose-purple max-w-none">
        <%= markdown(@post.content) %>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 mt-6">
      <%= link_to "← Back", root_path, class: "rounded-2xl px-5 py-2.5 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 hover:border-purple-300 dark:hover:border-purple-700 text-gray-700 dark:text-gray-300 font-medium text-sm transition-all duration-200 hover:shadow-md" %>
      <% if @auth_user && @post.can_edit?(@auth_user) %>
        <%= link_to "Edit", edit_user_post_path(@post.user, @post), class: "rounded-2xl px-5 py-2.5 bg-purple-600 hover:bg-purple-500 text-white font-medium text-sm transition-all duration-200 hover:shadow-lg hover:shadow-purple-200 dark:hover:shadow-purple-900/50 hover:-translate-y-0.5" %>
        <%= button_to "Delete", user_post_path(@post.user, @post), method: :delete, form_class: "inline", class: "rounded-2xl px-5 py-2.5 bg-red-50 dark:bg-red-950/40 hover:bg-red-100 dark:hover:bg-red-900/40 border border-red-100 dark:border-red-900/50 text-red-600 dark:text-red-400 font-medium text-sm cursor-pointer transition-all duration-200", data: { turbo_confirm: "Are you sure you want to delete this post?" } %>
      <% end %>
    </div>

  </article>
</div>
