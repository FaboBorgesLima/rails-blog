<%= form_with(model: post, url: post.persisted? ? user_post_path(post.user, post) : user_posts_path(post.user), local: true, class: "contents") do |form| %>
  <div class="flex flex-col gap-5">
    <% if post.errors.any? %>
      <div id="error_explanation" class="rounded-2xl bg-red-50 dark:bg-red-950/40 border border-red-200 dark:border-red-900/50 text-red-700 dark:text-red-400 px-5 py-4 text-sm mt-4">
        <h2 class="font-semibold mb-1"><%= pluralize(post.errors.count, "error") %> prevented this post from being saved:</h2>
        <ul class="list-disc ml-5 space-y-0.5">
          <% post.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <%= form.hidden_field :user_id %>
    <div class="space-y-1">
      <%= form.label :title, class: "block text-sm font-semibold text-gray-700 dark:text-gray-300" %>
      <%= form.text_field :title, class: ["mt-1 block w-full rounded-2xl border px-4 py-2.5 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 shadow-sm outline-none transition-all duration-200 focus:ring-2", {"border-gray-200 dark:border-gray-700 focus:border-purple-400 focus:ring-purple-100 dark:focus:ring-purple-900/50": post.errors[:title].none?, "border-red-400 dark:border-red-700 focus:border-red-400 focus:ring-red-100": post.errors[:title].any?}] %>
    </div>
    <div class="space-y-1">
      <%= form.label :description, class: "block text-sm font-semibold text-gray-700 dark:text-gray-300" %>
      <%= form.text_field :description, class: ["mt-1 block w-full rounded-2xl border px-4 py-2.5 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 shadow-sm outline-none transition-all duration-200 focus:ring-2", {"border-gray-200 dark:border-gray-700 focus:border-purple-400 focus:ring-purple-100 dark:focus:ring-purple-900/50": post.errors[:description].none?, "border-red-400 dark:border-red-700 focus:border-red-400 focus:ring-red-100": post.errors[:description].any?}] %>
    </div>
    <div class="space-y-1">
      <%= form.label :content, class: "block text-sm font-semibold text-gray-700 dark:text-gray-300" %>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5 mb-1">Markdown is supported — **bold**, _italic_, # headings, `code`, etc.</p>
      <%= form.textarea :content, rows: 20, class: ["mt-1 block w-full rounded-2xl border px-4 py-3 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-mono text-sm shadow-sm outline-none transition-all duration-200 focus:ring-2", {"border-gray-200 dark:border-gray-700 focus:border-purple-400 focus:ring-purple-100 dark:focus:ring-purple-900/50": post.errors[:content].none?, "border-red-400 dark:border-red-700 focus:border-red-400 focus:ring-red-100": post.errors[:content].any?}] %>
    </div>
    <div>
      <%= form.submit class: "w-full sm:w-auto rounded-2xl px-6 py-2.5 bg-gradient-to-r from-purple-600 to-violet-600 hover:from-purple-500 hover:to-violet-500 text-white font-semibold cursor-pointer transition-all duration-200 hover:shadow-lg hover:shadow-purple-200 dark:hover:shadow-purple-900/50 hover:-translate-y-0.5" %>
    </div>
  </div>
<% end %>
